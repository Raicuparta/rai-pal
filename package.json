{
	"name": "rai-mods",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "tauri dev",
		"build": "tauri build",
		"build-debug": "cross-env CARGO_TARGET_DIR=target/debug/standalone-build tauri build --debug --no-bundle",
		"vite": "vite",
		"tauri": "tauri",
		"update-icons": "tauri icon backend/graphics/icon-source.png",
		"frontend:build": "tsc && vite build",
		"frontend:dev": "vite",
		"lint": "prettier ./frontend --write && eslint --fix",
		"lint-only": "eslint eslint.config.mjs --fix",
		"find-unused": "cd backend && del index.scip &&  cargo workspace-unused-pub"
	},
	"prettier": {
		"useTabs": true,
		"singleAttributePerLine": true,
		"quoteProps": "as-needed",
		"endOfLine": "auto"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"dependencies": {
		"@eslint/compat": "2.0.5",
		"@eslint/eslintrc": "3.3.5",
		"@eslint/js": "9.39.4",
		"@mantine/code-highlight": "9.0.1",
		"@mantine/core": "9.0.1",
		"@mantine/hooks": "9.0.1",
		"@mantine/notifications": "9.0.1",
		"@tabler/icons-react": "3.41.1",
		"@tauri-apps/api": "2.10.1",
		"@tauri-apps/cli": "2.10.1",
		"@tauri-apps/plugin-dialog": "2.7.0",
		"@tauri-apps/plugin-os": "2.3.2",
		"@tauri-apps/plugin-process": "2.3.1",
		"@tauri-apps/plugin-shell": "2.3.5",
		"@tauri-apps/plugin-store": "2.4.2",
		"@tauri-apps/plugin-updater": "2.10.1",
		"@types/node": "25.5.2",
		"@types/react-dom": "19.2.3",
		"@types/react": "19.2.14",
		"@typescript-eslint/eslint-plugin": "8.58.1",
		"@typescript-eslint/parser": "8.58.1",
		"@vitejs/plugin-react": "6.0.1",
		"babel-plugin-react-compiler": "1.0.0",
		"cross-env": "10.1.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-react-compiler": "19.1.0-rc.2",
		"eslint-plugin-react-hooks": "7.0.1",
		"eslint-plugin-react-refresh": "0.5.2",
		"eslint-plugin-react": "7.37.5",
		"eslint": "9.39.4",
		"globals": "17.4.0",
		"jotai": "2.19.1",
		"postcss-preset-mantine": "1.18.0",
		"postcss-simple-vars": "7.0.1",
		"postcss": "8.5.9",
		"prettier": "3.8.1",
		"react-dom": "19.2.4",
		"react-virtuoso": "4.18.4",
		"react": "19.2.4",
		"typescript": "6.0.2",
		"vite": "8.0.7"
	}
}
